{
  "name": "codex-usage-remaining",
  "version": "0.1.0",
  "description": "Small Bun CLI for reading Codex usage remaining from the local app-server.",
  "type": "module",
  "bin": {
    "codex-usage-remaining": "./src/index.ts"
  },
  "scripts": {
    "run": "bun src/index.ts run",
    "start": "bun src/index.ts",
    "check": "bun build src/index.ts --target=bun --outdir=/tmp/codex-usage-remaining-build"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  }
}
